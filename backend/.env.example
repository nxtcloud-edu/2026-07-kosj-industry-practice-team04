# 「모아」 백엔드 환경변수 예시
# ─────────────────────────────────────────────────────
# 이 파일을 복사해 `.env`로 만들고 값을 채우세요:  cp .env.example .env
# `.env`는 .gitignore에 있어 커밋되지 않습니다. 절대 키를 공개 레포에 올리지 마세요.
# npm start 가 .env를 자동으로 읽습니다 (있을 때만).

# AI 이미지 분류 — Google Gemini (무료 키: https://aistudio.google.com/apikey)
# 설정하면 실제 비전 분류, 비우면 mock 분류로 동작합니다.
MOA_GEMINI_API_KEY=
# 기본 gemini-flash-latest (무료 할당량 있음). 429가 나면 다른 모델로 바꾸세요.
# MOA_GEMINI_MODEL=gemini-flash-latest

# 관리자 콘솔 토큰 — MVP 데모용 기본값. 실제 배포 시 반드시 다른 값으로 교체하세요.
MOA_ADMIN_TOKEN=demo-team04

# 배포 시: 프론트 origin으로 CORS 제한, 신뢰 프록시 뒤면 1
# MOA_ALLOWED_ORIGIN=https://your-frontend.example.com
# MOA_TRUST_PROXY=1
